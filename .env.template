# Copy to .env and fill in values. .env is gitignored.

# --- Slack (optional) ---
# Create an incoming webhook at https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# --- Telegram (optional) ---
# 1. Chat with @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your bot, then find your chat_id:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Email via SMTP (optional) ---
# For Gmail, use an App Password (not your account password):
# https://support.google.com/accounts/answer/185833
EMAIL_FROM=your@gmail.com
EMAIL_TO=recipient@example.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_PASSWORD=your-app-password
